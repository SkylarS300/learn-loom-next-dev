{
  "name": "learn-loom-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/predev.mjs && next dev",
    "test": "vitest run",
    "build": "prisma generate && next build",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:check": "docker ps && echo DATABASE_URL=$DATABASE_URL && echo SHADOW_DATABASE_URL=$SHADOW_DATABASE_URL",
    "icons": "node scripts/gen-icons.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "@tanstack/react-virtual": "^3.13.12",
    "bcryptjs": "^3.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "next": "15.3.2",
    "openai": "^5.12.2",
    "pdfjs-dist": "^5.2.133",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^2.15.4",
    "tree": "^0.1.3",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "knip": {
    "entry": [
      "app/**/*.{js,jsx,ts,tsx}",
      "src/**/*.{js,jsx,ts,tsx}"
    ],
    "ignore": [
      "**/*.d.ts"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "9.28.0",
    "eslint-config-next": "15.3.3",
    "prisma": "^6.14.0",
    "sharp": "^0.34.4",
    "tailwindcss": "^4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}