generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma" 
}

enum live_mode {
  READING
  GRAMMAR
  UPLOAD
}

// --- New enums for vocab/adaptivity ---
enum cefr_level {
  A1
  A2
  B1
  B2
  C1
  C2
  UNKNOWN
}

enum vocab_source {
  BOOK
  UPLOAD
  GRAMMAR
  LOOKUP
}


model assignment {
  id              Int             @id @default(autoincrement())
  classroomId     Int
  title           String
  description     String
  type            assignment_type
  dueDate         DateTime?
  startAt         DateTime?
  allowLate       Boolean         @default(true)
  latePenaltyPct  Int?
  weightPoints    Int?
  instructions    String?
  attachmentsJson Json            @default("[]")
  createdAt       DateTime        @default(now())

  completions assignmentcompletion[]
  classroom   classroom              @relation(fields: [classroomId], references: [id])

  targets assignmenttarget[]

  category String? // for quizzes
  subtopic String? // for quizzes

  bookId       Int? // for reading assignments: refers to index in book-content
  chapterIndex Int? // for reading assignments: refers to chapter in book
  uploadId     Int?
}

// ================================
// Vocabulary & Encounters (ESL)
// ================================

model Word {
  id         Int         @id @default(autoincrement())
  lemma      String      // normalized lowercase headword
  display    String?     // preferred display/casing
  phonetics  String?     // e.g., IPA or provider string
  pos        String?     // part of speech tag (coarse)
  cefrLevel  cefr_level  @default(UNKNOWN)
  createdAt  DateTime    @default(now())

  // relations
  encounters WordEncounter[]
  studies    WordStudy[]

  @@unique([lemma, pos])
  @@index([cefrLevel, pos])
}

model WordEncounter {
  id            Int          @id @default(autoincrement())
  anonId        String
  wordId        Int
  source        vocab_source
  // reading/book anchors
  bookIndex     Int?
  chapterIndex  Int?
  sentenceIndex Int?
  // upload anchor
  uploadId      Int?
  // grammar anchor
  concept       String?
  subTopic      String?
  // context around the encounter (trimmed)
  context       String?
  createdAt     DateTime     @default(now())

  word Word @relation(fields: [wordId], references: [id])

  @@index([anonId, createdAt])
  @@index([wordId])
  @@index([anonId, wordId, source])
}

model WordStudy {
  id           Int       @id @default(autoincrement())
  anonId       String
  wordId       Int
  // spaced repetition fields (SM-2–like, simplified)
  ease         Int       @default(130) // 130% starting ease
  reps         Int       @default(0)
  lapses       Int       @default(0)
  intervalDays Int       @default(0)
  nextDue      DateTime  @default(now())
  lastResult   String?   // "Again" | "Hard" | "Good" | "Easy"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  word Word @relation(fields: [wordId], references: [id])

  @@unique([anonId, wordId])
  @@index([anonId, nextDue])
}

// ================================
// Adaptive Grammar Ability (ELO-lite)
// ================================
model GrammarAbility {
  id        Int      @id @default(autoincrement())
  anonId    String
  concept   String
  subTopic  String
  ability   Float    @default(0)  // centered around 0; higher => harder items
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([anonId, concept, subTopic])
  @@index([updatedAt])
}

model assignmenttarget {
  id            Int     @id @default(autoincrement())
  assignmentId  Int
  anonId        String? // null => ALL (whole class target)
  overridesJson Json    @default("{}") // per-student overrides (dueAt, allowLate, etc.)

  assignment assignment @relation(fields: [assignmentId], references: [id])

  @@unique([assignmentId, anonId])
  @@index([assignmentId])
  @@index([anonId])
}

model bookcontent {
  id              Int     @id @default(autoincrement())
  chapters        Int
  chapterContents String
  chapterTitle    String?
}

model booklist {
  index  Int    @id @default(autoincrement())
  title  String
  author String
  cover  String
}

model classroom {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique(map: "Classroom_code_key")
  teacherId Int
  ownerAnon String? // optional anon owner (teacher-by-code)
  createdAt DateTime @default(now())

  assignments    assignment[]
  students       studentclassroom[]
  liveheartbeats liveheartbeat[]    @relation("ClassroomLiveHeartbeats")

  @@index([teacherId], map: "Classroom_teacherId_fkey")
  @@index([ownerAnon])
}

model grammarprogress {
  id           Int      @id @default(autoincrement())
  osis         Int?
  anonId       String? // for anonymous quiz logging
  concept      String
  subTopic     String
  score        Int
  numQuestions Int? // optional: total questions in the attempt
  durationMs   Int? // optional: time spent on the attempt (ms)
  isAi         Boolean? @default(false) // optional: tag AI-generated quizzes
  hintsUsed    Int? // number of hints used in this attempt
  createdAt    DateTime @default(now())

  @@index([anonId])
  @@index([concept, subTopic])
}

model aifeedback {
  id        Int      @id @default(autoincrement())
  anonId    String?
  concept   String
  subTopic  String
  prompt    String
  issue     String
  createdAt DateTime @default(now())

  @@index([anonId])
  @@index([createdAt])
}

model quizprogress {
  id        Int      @id @default(autoincrement())
  userId    Int?
  anonId    String?
  category  String
  subtopic  String
  score     Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([anonId])
}

model studentclassroom {
  id          Int     @id @default(autoincrement())
  studentId   Int?
  anonId      String?
  classroomId Int
  role        String  @default("student") // 'teacher' | 'student'
  displayName String?

  student   user?     @relation(fields: [studentId], references: [id])
  classroom classroom @relation(fields: [classroomId], references: [id])

  @@index([classroomId], map: "StudentClassroom_classroomId_fkey")
  @@index([studentId], map: "StudentClassroom_studentId_fkey")
  @@index([anonId])
  @@index([role])
  @@unique([classroomId, anonId]) // enables where: { classroomId_anonId: { ... } }
}

model uploadedtext {
  id             Int               @id @default(autoincrement())
  userId         Int?
  anonId         String?
  title          String
  content        String
  password       String? // Optional password
  createdAt      DateTime          @default(now())
  uploadview     uploadview[]
  uploadunlock   uploadunlock[]
  uploadprogress uploadprogress[] // back relation for uploadprogress
  visibility     upload_visibility @default(PRIVATE)
  shareCode      String?           @unique

  @@index([userId])
  @@index([anonId])
  @@index([visibility])
}

enum upload_visibility {
  PRIVATE
  CODED
  PUBLIC
}

model user {
  id        Int       @id @default(autoincrement())
  email     String    @unique(map: "User_email_key")
  password  String
  firstName String
  lastName  String
  grade     Int
  createdAt DateTime  @default(now())
  role      user_role @default(STUDENT)

  completions     assignmentcompletion[]
  studentClasses  studentclassroom[]
  readingprogress readingprogress[]
}

model assignmentcompletion {
  id           Int               @id @default(autoincrement())
  assignmentId Int
  userId       Int?
  anonId       String?
  status       submission_status @default(ASSIGNED)
  completedAt  DateTime?
  submittedAt  DateTime?
  gradedAt     DateTime?
  quizScore    Int? // legacy; keep
  scorePct     Int?
  scorePoints  Int?
  attemptCount Int               @default(0)
  attemptsJson Json              @default("[]") // array of attempt refs/metadata
  feedback     String?
  isLate       Boolean           @default(false)

  assignment assignment @relation(fields: [assignmentId], references: [id])
  user       user?      @relation(fields: [userId], references: [id])

  @@unique([anonId, assignmentId]) //  Prevent duplicate completions for anonymous users
  @@index([assignmentId])
  @@index([userId])
  @@index([anonId])
}

model readingprogress {
  id            Int      @id @default(autoincrement())
  userId        Int?
  anonId        String?
  bookIndex     Int
  chapterIndex  Int
  sentenceIndex Int?
  timeMs        Int?
  updatedAt     DateTime @updatedAt
  completedAt   DateTime @default(now())
  user          user?    @relation(fields: [userId], references: [id])

  @@unique([anonId, bookIndex, chapterIndex])
  @@index([userId])
  @@index([anonId])
  @@index([bookIndex, chapterIndex])
}

enum assignment_type {
  BOOK
  QUIZ
  UPLOAD
}

enum user_role {
  STUDENT
  TEACHER
}

enum submission_status {
  ASSIGNED
  SUBMITTED
  GRADED
  MISSING
  LATE
}

model uploadview {
  id       Int      @id @default(autoincrement())
  anonId   String
  uploadId Int
  viewedAt DateTime @default(now())

  uploadedtext uploadedtext @relation(fields: [uploadId], references: [id])

  @@unique([anonId, uploadId])
  @@index([anonId])
  @@index([uploadId])
}

model uploadunlock {
  id        Int      @id @default(autoincrement())
  anonId    String
  uploadId  Int
  createdAt DateTime @default(now())

  uploadedtext uploadedtext @relation(fields: [uploadId], references: [id])

  @@unique([anonId, uploadId])
  @@index([anonId])
  @@index([uploadId])
}

model uploadprogress {
  id         Int      @id @default(autoincrement())
  anonId     String
  uploadId   Int
  paraIndex  Int      @default(0)
  charOffset Int      @default(0)
  updatedAt  DateTime @updatedAt
  timeMs     Int      @default(0)

  uploadedtext uploadedtext @relation(fields: [uploadId], references: [id])

  @@unique([anonId, uploadId])
  @@index([anonId])
  @@index([uploadId])
}

model quizfeedback {
  id        Int      @id @default(autoincrement())
  anonId    String?
  concept   String
  subTopic  String
  prompt    String
  issue     String
  createdAt DateTime @default(now())

  @@index([anonId])
  @@index([concept, subTopic, createdAt])
}

model uploadunlockattempt {
  id          Int       @id @default(autoincrement())
  anonId      String
  uploadId    Int
  count       Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([anonId, uploadId])
  @@index([anonId])
  @@index([uploadId])
}

model liveheartbeat {
  id          Int        @id @default(autoincrement())
  classroomId Int
  anonId      String
  mode        live_mode?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  classroom classroom @relation("ClassroomLiveHeartbeats", fields: [classroomId], references: [id])

  @@unique([classroomId, anonId])
  @@index([classroomId, updatedAt])
  @@index([anonId])
}

model Note {
  id            String   @id @default(cuid())
  anonId        String
  targetType    String // 'book' | 'upload' | 'grammar'
  // ReadingPal anchors
  bookIndex     Int?
  uploadId      Int?
  chapterIndex  Int?
  sentenceIndex Int?
  wordIndex     Int?
  // Grammar anchors
  concept       String?
  subTopic      String?
  promptHash    String?
  // UX helpers
  anchorText    String?
  body          String
  tagsJson      Json     @default("[]") // JSON array of strings (portable)
  color         String? // optional note color (e.g. '#F59E0B' or a token)
  isBookmark    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([anonId, createdAt])
  @@index([anonId, targetType, bookIndex, chapterIndex, sentenceIndex])
  @@index([anonId, targetType, uploadId])
  @@index([anonId, targetType, concept, subTopic])
  // Needed for MySQL full-text search on notes:
  @@fulltext([body, anchorText])
}

model UserCode {
  id         String   @id @default(cuid())
  anonId     String
  shortCode  String   @unique
  longCode   String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([anonId])
}
